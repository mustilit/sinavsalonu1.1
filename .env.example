# Example environment variables for the monorepo
# Copy to .env and adjust for your environment

# Database (used by backend when running with Docker)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/sinavsalonu?schema=public"

# JWT secret for backend
JWT_SECRET="super_secret_key"

# Frontend API URL (for Vite)
VITE_API_URL="http://localhost:3000"

PORT=3000
NODE_ENV=development

# Veritabanı (Prisma - kritik işlemler transaction ile atomic)
DATABASE_URL="postgresql://user:password@localhost:5432/dal?schema=public"

# JWT (Güvenlik Katmanı)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=604800
